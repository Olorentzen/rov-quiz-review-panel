# ============================================================
# PDF Ingestion Review Panel — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Variables must be prefixed with VITE_ to be exposed to the browser.
# Vite will error at build time if a referenced env var is missing.

# Supabase project URL (Project Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (public) key (Project Settings → API → Project API keys → anon key)
# This key is safe to expose in the browser.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Deployment mode: 'hosted' (reviewers) or 'offline' (internal/admin with upload + runs)
# hosted: only Review + Packs tabs visible
# offline: all 4 tabs (Upload, Runs, Review, Packs) visible
VITE_DEPLOY_MODE=hosted

# API base URL — the backend FastAPI server URL
# For local development: http://localhost:8000/api
# For production hosted: set to your deployed FastAPI URL
VITE_API_BASE_URL=http://localhost:8000/api
